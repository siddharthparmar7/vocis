# API keys are NOT used via .env in this extension.
# They are stored at runtime in chrome.storage.local via the Settings panel (⚙ icon).
#
# This file documents what keys are required and where to get them.

# Anthropic (Claude) API key
# Get one at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# ElevenLabs API key
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...
