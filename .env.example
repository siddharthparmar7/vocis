# API keys are injected at build time by Vite (import.meta.env).
# Copy this file to .env and fill in your keys — then run `npm run build`.
#
# Keys set here take effect after a rebuild. The ⚙ settings panel in the sidebar
# can override them at runtime (stored in chrome.storage.local).

# Anthropic (Claude) API key
# Get one at: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=sk-ant-...

# ElevenLabs API key
# Get one at: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=...
