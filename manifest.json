{
  "manifest_version": 3,
  "name": "Vocis",
  "version": "0.1.0",
  "description": "Narrate any webpage and have a voice conversation with Claude about it.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Vocis"
  },
  "web_accessible_resources": [
    {
      "resources": ["content-script.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
